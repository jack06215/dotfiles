{{- $pypoetryDir := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $pypoetryDir = joinPath .chezmoi.homeDir ".cache/pypoetry/virtualenvs" -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   $pypoetryDir = joinPath .chezmoi.homeDir "" -}}
{{- else if eq .chezmoi.os "windows" -}}
{{-   $pypoetryDir = joinPath .chezmoi.homeDir "" -}}
{{- end -}}

{{- $firefoxProfilesDir := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $firefoxProfilesDir = joinPath .chezmoi.homeDir "Library/Application Support/Firefox/Profiles" -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   $firefoxProfilesDir = joinPath .chezmoi.homeDir ".mozilla/firefox" -}}
{{- else if eq .chezmoi.os "windows" -}}
{{-   $firefoxProfilesDir = joinPath .chezmoi.homeDir "AppData/Roaming/Mozilla/Firefox/Profiles" -}}
{{- end -}}

{{- $firefoxProfileId := "vfop1w54.default" -}}

{{- $zshPythonDir := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   if and (eq .chezmoi.hostname "jack06215") (eq .chezmoi.username "nacho") -}}
{{-     $zshPythonDir = joinPath $pypoetryDir "zsh-python-oevRg_sS-py3.13" -}}
{{-   else if and (eq .chezmoi.hostname "A0229") (eq .chezmoi.username "jack.cho") -}}
{{-     $zshPythonDir = joinPath .chezmoi.homeDir "Library/Caches/pypoetry/virtualenvs" "zsh-python-VlgDDfmw-py3.13" -}}
{{-   end -}}
{{- end -}}

sourceDir = {{ env "CHEZMOI_SOURCE_DIR" | default (joinPath .chezmoi.homeDir "workspace/jack06215/dotfiles") | quote }}

[data.git]
    name = "Jack Cho"
    email = "jack06215@gmail.com"
[data]
    shell = {{ output "sh" "-c" "echo $SHELL" | trim | quote }}
[data.myComputer]
    hostname = {{ .chezmoi.hostname | quote }}
    username = {{ .chezmoi.username | quote }}
    arch = {{ .chezmoi.arch | quote }}
    homeDir = {{ .chezmoi.homeDir | quote }}
    isCompanyMachine = {{ env "IS_COMPANY_MACHINE" | eq "true" | toString | trim }}
    isDarwin = {{ eq .chezmoi.os "darwin" | toString | trim }}
    isLinux = {{ eq .chezmoi.os "linux" | toString | trim }}
    isWSL2 = {{ output "bash" "-c" "[[ \"$(uname -s)\" == 'Linux' ]] && [[ -r /proc/version ]] && grep -qi microsoft /proc/version 2>/dev/null && echo true || echo false" | trim }}
    isWindows = {{ eq .chezmoi.os "windows" | toString | trim }}
    isArm = {{ eq .chezmoi.arch "arm64" | toString | trim }}
    isX86 = {{ eq .chezmoi.arch "amd64" | toString | trim }}
[data.pypoetry]  
    pypoetryDir = {{ $pypoetryDir | quote }}
    zshPythonDir = {{ $zshPythonDir | quote }}
[data.firefox]
    profile = {{ $firefoxProfileId | quote }}
    profileDirBase = {{ $firefoxProfilesDir | quote }}
    profileDir = {{ joinPath $firefoxProfilesDir $firefoxProfileId | quote }}
[data.xdg]
    configHome = {{ env "XDG_CONFIG_HOME" | default (joinPath .chezmoi.homeDir ".config") | quote }}
    dataHome = {{ env "XDG_DATA_HOME" | default (joinPath .chezmoi.homeDir ".local/share") | quote }}
    cacheHome = {{ env "XDG_CACHE_HOME" | default (joinPath .chezmoi.homeDir ".cache") | quote }}
[template]
    options = ["missingkey=error"]

[diff]
    # run_onchange_ scripts embed dotfile content via `include`, so any dotfile
    # edit changes the script's hash and chezmoi diff would otherwise dump the
    # entire script body as a "new file". Excluding scripts keeps diff output
    # to actual file changes only.
    exclude = ["scripts"]
