[data.git]
    name = "Jack Cho"
    email = "jack06215@gmail.com"
[data]
    shell = {{ output "sh" "-c" "echo $SHELL" | trim | quote }}
[data.myComputer]
    hostname = {{ .chezmoi.hostname | quote }}
    username = {{ .chezmoi.username | quote }}
    arch = {{ .chezmoi.arch | quote }}
    homeDir = {{ .chezmoi.homeDir | quote }}
    isCompanyMachine  = {{ env "IS_COMPANY_MACHINE" | eq "true" | toString | trim }}
    isDarwin = {{ eq .chezmoi.os "darwin" | toString | trim }}
    isLinux = {{ eq .chezmoi.os "linux" | toString | trim }}
    isWindows = {{ eq .chezmoi.os "windows" | toString | trim }}
    isArm = {{ eq .chezmoi.arch "arm64" | toString | trim }}
    isX86 = {{ eq .chezmoi.arch "amd64" | toString | trim }}
[data.xdg]
    configHome = {{ env "XDG_CONFIG_HOME" | default (joinPath .chezmoi.homeDir ".config") | quote }}
    dataHome = {{ env "XDG_DATA_HOME" | default (joinPath .chezmoi.homeDir ".local/share") | quote }}
    cacheHome = {{ env "XDG_CACHE_HOME" | default (joinPath .chezmoi.homeDir ".cache") | quote }}
[template]
  options = ["missingkey=error"]
