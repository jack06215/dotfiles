local M = {}

--- Trim leading/trailing whitespace from a chezmoi-rendered long string.
--- Use with [=[ ... ]=] to keep template directives out of bare Lua tokens.
---
--- Example:
---   local val = M.tmpl([=[
---   {{- if .myComputer.isDarwin -}}
---       /bin/zsh
---   {{- else -}}
---       pwsh
---   {{- end -}}
---   ]=])
---
---@param s string
---@return string
function M.tmpl(s)
	local result, _ = s:gsub("^%s*(.-)%s*$", "%1")
	return result
end

--- Check if a chezmoi boolean data key is true at apply time.
--- Key must match an entry in M._data.
---
--- Example:
---   if tmpl.is_true("myComputer.isDarwin") then
---     config.macos_window_background_blur = 40
---   end
---
M._data = {
	["myComputer.isDarwin"] = M.tmpl([=[{{- if index .myComputer "isDarwin" -}}true{{- end -}}]=]) == "true",
	["myComputer.isWindows"] = M.tmpl([=[{{- if index .myComputer "isWindows" -}}true{{- end -}}]=]) == "true",
	["myComputer.isLinux"] = M.tmpl([=[{{- if index .myComputer "isLinux" -}}true{{- end -}}]=]) == "true",
	["myComputer.isArm"] = M.tmpl([=[{{- if index .myComputer "isArm" -}}true{{- end -}}]=]) == "true",
	["myComputer.isX86"] = M.tmpl([=[{{- if index .myComputer "isX86" -}}true{{- end -}}]=]) == "true",
	["myComputer.isCompanyMachine"] = M.tmpl([=[{{- if index .myComputer "isCompanyMachine" -}}true{{- end -}}]=])
		== "true",
}

---@param key string   dot-separated chezmoi data path
---@return boolean
function M.is_true(key)
	return M._data[key] == true
end

--- Build a string list, appending each extra value only if it is non-empty.
--- Useful for constructing command arrays where some arguments are platform-
--- conditional and render to "" when not applicable.
---
--- Example:
---   local prog = M.compact(shell, flag, extra)
---   -- { "/bin/zsh", "--login" }  on darwin
---   -- { "pwsh" }                 on windows/linux (flag and extra were "")
---
---@param ... string   one or more strings; empty strings are omitted
---@return string[]
function M.compact(...)
	local args = table.pack(...)
	local result = {}
	for i = 1, args.n do
		if args[i] ~= "" then
			table.insert(result, args[i])
		end
	end
	return result
end

--- Resolve the primary modifier key for the current platform.
--- Returns "CMD" on macOS, "CTRL" everywhere else.
---
---@return string
function M.mod()
	return M.tmpl([=[
        {{- if .myComputer.isDarwin -}}
            CMD
        {{- else -}}
            CTRL
        {{- end -}}
      ]=])
end

return M
